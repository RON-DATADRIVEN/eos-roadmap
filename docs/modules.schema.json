{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "id": { "type": "string" },
      "nombre": { "type": "string" },
      "descripcion": { "type": "string" },
      "fase": {
        "type": "string",
        "enum": [
          "Prototipado",
          "Desarrollo",
          "Test",
          "Staging",
          "Deploy",
          "Archivado"
        ]
      },
      "estado": {
        "type": "string",
        "enum": [
          "Planificado",
          "En curso",
          "Hecho",
          "En prototipo",
          "En desarrollo",
          "En pruebas",
          "En validación",
          "Liberado",
          "Archivado",
          "Reportado",
          "En atención",
          "Resuelto"
        ]
      },
      "porcentaje": { "type": "integer", "minimum": 0, "maximum": 100 },
      "propietario": { "type": "string" },
      "inicio": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
      "eta": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
      "tipo": {
        "type": "string",
        "description": "Clasificación pública del elemento del roadmap",
        "enum": ["feature", "bug"]
      },
      "enlaces": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "label": { "type": "string" },
            "url": { "type": "string", "format": "uri" }
          },
          "required": ["label", "url"]
        }
      }
    },
    "required": ["id", "nombre", "fase", "estado", "porcentaje", "tipo"]
  }
}
